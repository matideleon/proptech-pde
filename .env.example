# ============================================================
# PROPTECH PDE — Variables de Entorno
# Copiar como .env y completar con valores reales
# ============================================================

# ─── APP ────────────────────────────────────────────────────
APP_NAME="PropTech PDE"
APP_ENV=development
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── DATABASE ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://proptech:proptech123@localhost:5432/proptech_pde
DATABASE_SYNC_URL=postgresql://proptech:proptech123@localhost:5432/proptech_pde
POSTGRES_USER=proptech
POSTGRES_PASSWORD=proptech123
POSTGRES_DB=proptech_pde
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ─── SUPABASE ───────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# ─── REDIS ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_URL=redis://localhost:6379/1

# ─── JWT ────────────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── AI APIs ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_PREMIUM=gpt-4o
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ─── SCRAPING ───────────────────────────────────────────────
SCRAPING_DELAY_MIN=2
SCRAPING_DELAY_MAX=5
SCRAPING_MAX_RETRIES=3
SCRAPING_TIMEOUT=30
USE_PROXY=false
PROXY_LIST=http://proxy1:port,http://proxy2:port
BROWSERLESS_URL=ws://localhost:3000

# ─── GRUPOS DE FACEBOOK (alquileres ofrecidos/solicitados) ──
# Sesión del navegador logueado (header Cookie). Extraer c_user y xs desde
# DevTools → Application → Cookies → facebook.com. ⚠️ Viola ToS de FB.
FB_SESSION_COOKIE=
# IDs o slugs de los grupos a monitorear, separados por coma.
FB_GROUP_IDS=

# ─── CREDENCIALES DE PORTALES ───────────────────────────────
# MercadoLibre: su API exige OAuth desde 2024.
# Obtené un token gratis en https://developers.mercadolibre.com.uy
# (crear app → Client ID/Secret → generar access_token)
MERCADOLIBRE_ACCESS_TOKEN=
# Facebook Marketplace: requiere sesión iniciada.
# Exportá storage_state de Playwright con una cuenta logueada.
FACEBOOK_SESSION_FILE=./facebook_session.json

# ─── NOTIFICATIONS ──────────────────────────────────────────
# WhatsApp Business API
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_ID=your-phone-number-id
WHATSAPP_TOKEN=your-whatsapp-token
WHATSAPP_VERIFY_TOKEN=your-verify-token
# Destinatario del digest diario (formato internacional sin +, ej. 59899123456)
WHATSAPP_ALERT_TO=

# Digest diario de nuevas propiedades (job Celery 7:00 America/Montevideo)
# URL pública base usada para el link del dashboard en el mensaje
PUBLIC_BASE_URL=https://dynamiclabsai.com
# Ventana en horas para considerar una propiedad "nueva"
DIGEST_WINDOW_HOURS=24

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Email (SendGrid o SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SENDGRID_API_KEY=SG...
FROM_EMAIL=noreply@proptech.uy
FROM_NAME="PropTech PDE"

# ─── EXTERNAL APIS ──────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your-google-maps-key
GEOCODIO_API_KEY=your-geocodio-key

# ─── CELERY ─────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/3
CELERY_TASK_ALWAYS_EAGER=false

# ─── FRONTEND ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── SENTRY (opcional) ──────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn

# ─── METABASE ───────────────────────────────────────────────
METABASE_SECRET_KEY=your-metabase-secret
